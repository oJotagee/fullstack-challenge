{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend",
    "frontend/*"
  ],
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --remove-orphans",
    "test": "bun test",
    "test:e2e": "playwright test",
    "prisma:generate:games": "bunx prisma generate --config services/games/prisma.config.ts",
    "prisma:generate:wallets": "bunx prisma generate --config services/wallets/prisma.config.ts",
    "prisma:generate": "bun run prisma:generate:games && bun run prisma:generate:wallets",
    "prisma:migrate:dev:games": "bunx prisma migrate dev --config services/games/prisma.config.ts",
    "prisma:migrate:dev:wallets": "bunx prisma migrate dev --config services/wallets/prisma.config.ts",
    "prisma:migrate:reset:games": "bunx prisma migrate reset --config services/games/prisma.config.ts",
    "prisma:migrate:reset:wallets": "bunx prisma migrate reset --config services/wallets/prisma.config.ts",
    "prisma:migrate:reset": "bun run prisma:migrate:reset:games && bun run prisma:migrate:reset:wallets",
    "prisma:studio:games": "bunx prisma studio --config services/games/prisma.config.ts",
    "prisma:studio:wallets": "bunx prisma studio --config services/wallets/prisma.config.ts",
    "prisma:seed:wallets": "bunx prisma db seed --config services/wallets/prisma.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test:wallets": "bun --cwd services/wallets test",
    "test:games": "bun --cwd services/games test",
    "test:unit": "bun run test:wallets && bun run test:games",
    "test:coverage:wallets": "bun --cwd services/wallets test --coverage",
    "test:coverage:games": "bun --cwd services/games test --coverage --pass-with-no-tests",
    "test:coverage": "bun run test:coverage:wallets && bun run test:coverage:games"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  }
}
